# ZerσSigma Algo Cockpit — machine-specific settings
# Copy this file to `.env` and fill in. `.env` is gitignored.

# ----- ZerσSigma API (StructureProvider) -----
# SAFE DEFAULT: the cockpit boots on the stub StructureProvider — no network,
# no creds. Flip ZS_STRUCTURE_PROVIDER=zerosigma_api below to hit the real
# API. The public_only auth mode lets you smoke-test live ZS reads with
# ZERO secrets — see "Read paths" below.

# Base URL of the ZerσSigma public API. No trailing slash.
# Example for live: https://api.zerosigma.example
ZS_API_BASE_URL=

# Auth mode: how the cockpit calls /api/v1/*.
# Allowed: none | public_only | bearer | login | service_token
#   none           — disable ZS API (cockpit runs on the stub provider).
#   public_only    — call public endpoints (/market/snapshot) WITHOUT an
#                    Authorization header. Subscription-gated endpoints
#                    (/exposure/series, /exposure/ddoi) are skipped — VW
#                    PUT_CEILING / CALL_FLOOR / MaxVol fields will be None.
#                    NO secrets required.
#   bearer         — paste a long-lived JWT into ZS_API_TOKEN below.
#   login          — POST /auth/login with ZS_API_USERNAME + ZS_API_PASSWORD.
#   service_token  — POST /auth/service-token with ZS_API_USERNAME + ZS_API_SERVICE_KEY.
ZS_API_AUTH_MODE=public_only

# Option A) paste a JWT (mode = bearer). Token TTL is ~15 min server-side.
ZS_API_TOKEN=

# Option B) login flow (mode = login).
ZS_API_USERNAME=
ZS_API_PASSWORD=

# Option C) server-to-server service token (mode = service_token).
# Same ZS_API_USERNAME above; the secret here matches the server's
# ADMIN_SERVICE_KEY env. The caller must be an admin user.
ZS_API_SERVICE_KEY=

# Default symbol(s) to scan
ZS_PRIMARY_SYMBOL=SPX

# Refresh cadence (seconds). Defaults are conservative.
ZS_REFRESH_SECONDS=60

# HTTP behavior. Phase 2.5 default: a single try (no retry storm) — bump up
# only after the live integration is stable.
ZS_API_TIMEOUT_SECONDS=10
ZS_API_VERIFY_SSL=true
ZS_API_MAX_RETRIES=1

# Which subset of endpoints to enable.
# `enable_exposure_series` requires an active subscription on the calling
# account AND an auth mode that uses a Bearer token (bearer / login /
# service_token). Under public_only OR none, the provider always SKIPS
# /exposure/series — VW PUT_CEILING / CALL_FLOOR / MaxVol fields land as
# None instead of failing the whole snapshot.
ZS_API_ENABLE_EXPOSURE_SERIES=false
ZS_API_ENABLE_DDOI=false

# Which StructureProvider the cockpit boots into. Safe default = stub.
# Set to "zerosigma_api" to hit the real ZS API using the auth_mode above.
#
# Read paths:
#   # safest — never touches network:
#   ZS_STRUCTURE_PROVIDER=stub
#
#   # public live smoke test — no secrets:
#   ZS_STRUCTURE_PROVIDER=zerosigma_api
#   ZS_API_AUTH_MODE=public_only
#   ZS_API_BASE_URL=https://api.zerosigma.example
#
#   # authenticated — needed to populate PUT_CEILING / CALL_FLOOR / MaxVol:
#   ZS_STRUCTURE_PROVIDER=zerosigma_api
#   ZS_API_AUTH_MODE=login   (or bearer / service_token)
#   ZS_API_ENABLE_EXPOSURE_SERIES=true
#   ... matching credential vars above ...
ZS_STRUCTURE_PROVIDER=stub

# ----- Broker (QuoteProvider + ExecutionProvider) -----
# Not connected in Phase 1. Leave undecided.
# Allowed: undecided | tastytrade | webull | alpaca | tradier | ibkr | schwab
BROKER_PROVIDER=undecided
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ACCOUNT_ID=
BROKER_PAPER_MODE=true


# ----- Phase 3: Tastytrade capability probe (read-only, NO order submission) -----
# Used by `python -m scripts.probe_tastytrade ...` only. NOT wired into the
# scanner or the production QuoteProvider yet — those land after Dan reviews
# the probe results.
#
# SAFETY:
#   - Real credentials go ONLY in your local `.env`. `.env` is gitignored.
#   - The probe NEVER POSTs to /orders or /complex-orders (live submit paths).
#   - The probe NEVER writes anything to Tastytrade — read-only by design.
#   - Order dry-run (no-routing preview) is gated behind an explicit
#     `--dry-run-vertical` CLI flag and disabled by default.
#
# Where to obtain credentials:
#   - Production:    your normal Tastytrade login (https://tastytrade.com).
#   - Certification: register a sandbox account at
#                    https://developer.tastytrade.com/sandbox.
#                    Cert quotes are 15-min delayed; positions reset every 24h.

# Environment selector: "production" | "certification" (default: certification)
TASTY_ENV=certification

# Base URL. When empty, the probe picks one based on TASTY_ENV.
#   production    → https://api.tastyworks.com
#   certification → https://api.cert.tastyworks.com
# Override only if Tastytrade rotates hosts.
TASTY_BASE_URL=

# ── Auth path A — OAuth2 refresh flow (recommended; long-lived) ──
# Register a Personal OAuth Application in the Tastytrade dev UI:
#   developer.tastytrade.com → My Apps → Create
# Capture the refresh_token ONCE via the interactive authorization-code
# flow (one-time manual step using TASTY_REDIRECT_URI), then drop it in
# .env so the probe can refresh non-interactively.
TASTY_CLIENT_ID=
TASTY_CLIENT_SECRET=
TASTY_REDIRECT_URI=https://localhost:8000
TASTY_REFRESH_TOKEN=

# Scopes requested by the OAuth app. The parser accepts BOTH
# space-separated and comma-separated formats:
#     TASTY_SCOPES=read trade openid
#     TASTY_SCOPES=read,trade,openid
# `trade` may be present for FUTURE execution capability — its presence
# alone does NOT enable order submission in this repo. See safety gate
# below.
TASTY_SCOPES=read trade openid

# ── Auth path B — legacy /sessions (fallback; Tasty announced sunset) ──
# Used only when OAuth fields above are not all set. BARE Authorization
# header (no `Bearer ` prefix) for any subsequent call.
TASTY_USERNAME=
TASTY_PASSWORD=

# Optional — account-scoped operations pick this one. If empty, the
# probe uses the first account returned by /customers/me/accounts.
TASTY_ACCOUNT_NUMBER=

# ── SAFETY GATES (Phase 3 — read-only probe) ──
# These two knobs are independent on purpose:
#   * `TASTY_ALLOW_TRADE_SCOPE` lets your OAuth app advertise the
#     `trade` scope without the probe complaining. Useful when the app
#     is registered for future execution but the probe is read-only.
#   * `TASTY_ENABLE_ORDER_SUBMISSION` is the HARD execution gate. It
#     defaults to false, and Phase 3 NEVER reads it for anything but
#     reporting — the probe doesn't expose a submit path at all. The
#     gate exists so future execution code has one explicit place to
#     check; trade scope alone is NEVER sufficient.
TASTY_ALLOW_TRADE_SCOPE=true
TASTY_ENABLE_ORDER_SUBMISSION=false

# Whether the probe should fetch a DXLink quote-streamer token. Setting
# this true only fetches GET /api-quote-tokens; it does NOT open the
# WebSocket. Default: false.
TASTY_USE_DXLINK=false

# HTTP behavior. Conservative defaults; Tastytrade rate limits are not
# publicly documented (community SDKs self-throttle ~2 req/s).
TASTY_TIMEOUT_SECONDS=10
TASTY_VERIFY_SSL=true

# ----- Execution mode -----
# Allowed (Phase 1): disabled | local_paper | manual_trade_tracking
# Future: broker_paper | manual_confirm | live_tiny | live
EXECUTION_MODE=local_paper

# ----- Local paths -----
# All paths can be absolute or repo-relative. Defaults stay inside the repo.
DATA_DIR=./data
OUTPUT_DIR=./outputs

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Streamlit -----
STREAMLIT_PORT=8501
STREAMLIT_SERVER_ADDRESS=127.0.0.1
