# ZerσSigma Algo Cockpit — machine-specific settings
# Copy this file to `.env` and fill in. `.env` is gitignored.

# ----- ZerσSigma API (StructureProvider) -----
# Base URL of the ZerσSigma public API. No trailing slash.
ZS_API_BASE_URL=https://api.zerosigma.example

# Auth mode: how the cockpit obtains a Bearer JWT for /api/v1/*.
# Allowed: none | bearer | login | service_token
#   none           — disable ZS API (use the stub StructureProvider)
#   bearer         — paste a long-lived JWT into ZS_API_TOKEN below
#   login          — POST /auth/login with ZS_API_USERNAME + ZS_API_PASSWORD
#   service_token  — POST /auth/service-token with ZS_API_USERNAME + ZS_API_SERVICE_KEY
ZS_API_AUTH_MODE=none

# Option A) paste a JWT (mode = bearer). Token TTL is ~15 min server-side.
ZS_API_TOKEN=

# Option B) login flow (mode = login).
ZS_API_USERNAME=
ZS_API_PASSWORD=

# Option C) server-to-server service token (mode = service_token).
# Same ZS_API_USERNAME above; the secret here matches the server's
# ADMIN_SERVICE_KEY env. The caller must be an admin user.
ZS_API_SERVICE_KEY=

# Default symbol(s) to scan
ZS_PRIMARY_SYMBOL=SPX

# Refresh cadence (seconds). Defaults are conservative.
ZS_REFRESH_SECONDS=60

# HTTP behavior
ZS_API_TIMEOUT_SECONDS=10
ZS_API_VERIFY_SSL=true
ZS_API_MAX_RETRIES=3

# Which subset of endpoints to enable.
# The /exposure/* endpoints require an active subscription on the calling
# account. If false, the provider skips them and the PUT_CEILING/CALL_FLOOR/
# MaxVol fields are reported as None (instead of failing the whole snapshot).
ZS_API_ENABLE_EXPOSURE_SERIES=true
ZS_API_ENABLE_DDOI=false

# ----- Broker (QuoteProvider + ExecutionProvider) -----
# Not connected in Phase 1. Leave undecided.
# Allowed: undecided | tastytrade | webull | alpaca | tradier | ibkr | schwab
BROKER_PROVIDER=undecided
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ACCOUNT_ID=
BROKER_PAPER_MODE=true

# ----- Execution mode -----
# Allowed (Phase 1): disabled | local_paper | manual_trade_tracking
# Future: broker_paper | manual_confirm | live_tiny | live
EXECUTION_MODE=local_paper

# ----- Local paths -----
# All paths can be absolute or repo-relative. Defaults stay inside the repo.
DATA_DIR=./data
OUTPUT_DIR=./outputs

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Streamlit -----
STREAMLIT_PORT=8501
STREAMLIT_SERVER_ADDRESS=127.0.0.1
